# HUD Pipeline — Environment Variables
# Copy this file to .env and fill in your actual values
# Then update 4_video_worker.py to read from this file (or paste values directly)

# Supabase connection (required for video worker)
SUPABASE_URL=https://lpqjndfjbenolhneqzec.supabase.co
SUPABASE_SERVICE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE
# Get from: Supabase Dashboard → Project Settings → API → service_role

# OpenAI API key (optional — enables AI title/description generation)
OPENAI_API_KEY=sk-...your-key-here...

# Worker settings
WORKER_POLL_SEC=30
WORKER_BATCH=3
